{
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "alpinejs": "^3.15.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "vite": "^7.2.2"
  },
  "name": "tollerus",
  "version": "1.0.7",
  "description": "A conlang dictionary Laravel package - the luxurious way to build, track, and browse your conlang's lexical data",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.8.18",
    "browserslist": "^4.26.3",
    "caniuse-lite": "^1.0.30001751",
    "electron-to-chromium": "^1.5.237",
    "escalade": "^3.2.0",
    "fraction.js": "^4.3.7",
    "nanoid": "^3.3.11",
    "node-releases": "^2.0.25",
    "normalize-range": "^0.1.2",
    "picocolors": "^1.1.1",
    "postcss-value-parser": "^4.2.0",
    "source-map-js": "^1.2.1",
    "update-browserslist-db": "^1.1.3"
  },
  "scripts": {
    "build": "npm run build:tailwind && npm run build:vite",
    "build:tailwind": "tailwindcss -i ./resources/css/tollerus.css -o ./dist/tollerus.css --minify",
    "build:vite": "vite build --config vite.config.js",
    "dev": "npm run dev:tailwind",
    "dev:tailwind": "tailwindcss -i ./resources/css/tollerus.css -o ./dist/tollerus.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
